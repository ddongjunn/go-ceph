{
  "name": "Ceph Dev Container",
  "dockerFile": "Dockerfile",
  "context": "..",
  "runArgs": ["-p", "9080:9080"],
  "appPort": [9080],
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash"
  },
  "postCreateCommand": "go mod tidy",
  "remoteUser": "root",
  "mounts": [
    "source=${localEnv:HOME}/Desktop/workspace/ceph-config, target=/etc/ceph,type=bind"
  ]
}